:root {
    --bg: #0b0f1a;
    --primary: #ff7a18;
    --secondary: #ffb347;
    --text: #eaeaea;
    --glass: rgba(255,255,255,0.05);
}

/* RESET */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Outfit', sans-serif;
    background: radial-gradient(circle at top, #1a1f35, #0b0f1a);
    color: var(--text);
}

/* NAVBAR */
.navbar {
    display: flex;
    justify-content: space-between;
    padding: 20px 60px;
    position: fixed;
    width: 100%;
    backdrop-filter: blur(10px);
}

.navbar nav a {
    margin-left: 20px;
    color: var(--text);
    text-decoration: none;
}

/* HERO */
.hero {
    height: 100vh;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
}

.hero h1 {
    font-family: 'Clash Display', sans-serif;
    font-size: 3.5rem;
}

.hero span {
    color: var(--primary);
}

.btn {
    margin-top: 20px;
    display: inline-block;
    padding: 12px 25px;
    background: linear-gradient(45deg, var(--primary), var(--secondary));
    border-radius: 30px;
    text-decoration: none;
    color: #000;
    font-weight: bold;
}

/* SERVICES */
.services {
    padding: 100px 60px;
    text-align: center;
}

.cards {
    display: flex;
    gap: 30px;
    margin-top: 40px;
}

.card {
    flex: 1;
    padding: 30px;
    background: var(--glass);
    border-radius: 20px;
    transition: 0.3s;
}

.card:hover {
    transform: translateY(-10px);
    background: rgba(255,255,255,0.1);
}

/* ABOUT */
.about {
    padding: 100px 60px;
    text-align: center;
}

/* CONTACT */
.contact {
    padding: 100px 60px;
    text-align: center;
}

.contact-box {
    max-width: 500px;
    margin: auto;
}

form {
    margin-top: 20px;
}

input, textarea {
    width: 100%;
    margin: 10px 0;
    padding: 12px;
    border-radius: 10px;
    border: none;
}

button {
    padding: 12px;
    width: 100%;
    background: var(--primary);
    border: none;
    border-radius: 10px;
    cursor: pointer;
}

/* FOOTER */
footer {
    text-align: center;
    padding: 20px;
}

// Smooth Scroll
document.querySelectorAll("a[href^='#']").forEach(anchor => {
    anchor.addEventListener("click", function(e) {
        e.preventDefault();
        document.querySelector(this.getAttribute("href"))
            .scrollIntoView({ behavior: "smooth" });
    });
});

// Fake Form Submit (Replace later with backend)
document.getElementById("contactForm").addEventListener("submit", function(e){
    e.preventDefault();
    alert("Message sent! We will contact you soon.");
});
